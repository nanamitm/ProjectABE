  "license": "MIT",
  "main": "electron.js",
  "scripts": {
    "test": "gulp test",
    "build:electron": "node scripts/build-electron.js",
    "build:web": "node scripts/build-target.js web",
    "build:mobile": "node scripts/build-target.js mobile",
    "build:android": "node scripts/build-android.js",
    "test:electron": "npm run build:electron && node scripts/smoke-electron.js",
    "package:electron": "npm run build:electron && electron-builder --projectDir build --config ..\\electron-builder.yml --dir",
    "package:electron:installer": "npm run build:electron && electron-builder --projectDir build --config ..\\electron-builder.yml --win nsis",
    "watch:electron": "node scripts/watch-electron.js"
  },
  "dependencies": {
    "cordova": "13.0.0",
    "dry-di": "^0.5.9",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "html5-fs": "^0.1.1",
    "jszip": "3.10.1",
    "localforage": "^1.5.0",
    "minimist": "^1.2.0"
  },
  "devDependencies": {
    "babel-plugin-import-glob": "^2.0.0",
    "babel-plugin-transform-class-properties": "^6.24.1",
    "babel-preset-env": "^1.5.2",
    "babelify": "^7.3.0",
    "browserify": "^14.4.0",
    "detect-newline": "^2.1.0",
    "gulp": "^3.9.1",
    "gulp-browserify": "^0.5.1",
    "gulp-clean": "^0.3.2",
    "gulp-concat": "^2.6.1",
    "gulp-livereload": "^3.8.1",
    "gulp-sequence": "^0.4.6",
    "gulp-sourcemaps": "^2.6.2",
    "gulp-uglify": "^3.0.0",
